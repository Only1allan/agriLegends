{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "21st-dev-magic": {
      "type": "local",
      "command": ["npx", "-y", "@21st-dev/magic@latest"],
      "environment": {
        "API_KEY": "<REDACTED_21ST_API_KEY>"
      },
      "timeout": 5000
    }
  }
}
