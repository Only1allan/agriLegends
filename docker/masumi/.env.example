# =============================================================================
# Masumi Node Environment — FarmWise
# =============================================================================
# Copy to .env and fill in your values before running: docker compose up -d
#
# Admin panel:     http://localhost:3001/admin    (login with ADMIN_KEY)
# Registry API:    http://localhost:3000/api/v1
# Payment API:     http://localhost:3001/api/v1
# =============================================================================

# Cardano network: "Preprod" or "Mainnet"
NETWORK=Preprod

# Encryption key for wallet secrets stored in the payment database.
# Must be at least 20 characters. Generate with: openssl rand -hex 32
ENCRYPTION_KEY="change_this_to_secure_string_at_least_20_chars"

# Admin key for the Masumi Registry and Payment admin panel.
# Must be at least 15 characters. You log into http://localhost:3001/admin with this.
ADMIN_KEY="change_this_to_secure_string_at_least_15_chars"

# Blockfrost project ID for the selected Cardano network.
# NOTE: Blockfrost calls this a "project ID", not an API key.
# Get yours at https://blockfrost.io → Create Project → select Preprod → copy Project ID
# The env var name BLOCKFROST_API_KEY_PREPROD is what Masumi expects internally.
BLOCKFROST_API_KEY_PREPROD=""
